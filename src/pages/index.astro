---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta
    name="description"
    content="DEAD OR ALIVE 6（DOA6）のコスチューム別パンツ差分・インナー差分をまとめた非公式ファンサイトです。マリー、ほのかなどの衣装ごとのA/X/Y/R2差分を画像付きで掲載しています。"
  />
  <title>DOA6 パンツ早見表 | DEAD OR ALIVE 6 コスチューム差分まとめ</title>
  <!-- Cloudflare Web Analytics -->
  <script
    defer
    src='https://static.cloudflareinsights.com/beacon.min.js'
    data-cf-beacon='{"token":"29cbb7e01e3646fa9e142319f27afc10"}'
  ></script>
  <!-- End Cloudflare Web Analytics -->
</head>

<body>
  <h1>DOA6 パンツ早見表</h1>
  <p class="site-description">
    DEAD OR ALIVE 6（DOA6）のコスチューム差分をまとめた非公式ファンサイトです。<br />
    祝！LAST ROUND発売！DOA7開発決定！
  </p>

  <a href="#nico">NiCO</a>
  <a href="#marie">マリー</a>
  <a href="#honoka">ほのか</a>

  {characters.map((character) => (
    <section>
      <h2 id={character.id}>{character.name}</h2>

      {character.costumes.map((costume) => (
        <section class="costume-section">
          <h3>{costume.name}</h3>
          <p class="costume-comment">{costume.comment}</p>

          <div class="variants">
            {variants.map((variant) => (
              <div class="variant">
                <p>{variant.label}</p>
                <img
                  class="zoomable-image"
                  src={`/images/${character.id}/${costume.id}/${variant.key}.webp`}
                  alt={`${character.name} ${costume.name} ${variant.label}`}
                />
              </div>
            ))}
          </div>
        </section>
      ))}
    </section>
  ))}

<footer class="site-footer">
  <hr />
  <p>
    当サイトは個人運営の非公式ファンサイトです。<br />
    「DEAD OR ALIVE 6」および関連する画像・名称の著作権は
    コーエーテクモゲームスに帰属します。
  </p>

  <p>
    掲載している画像はゲームプレイ中に撮影したスクリーンショットです。
  </p>
  <!--
  <p>
    ご意見・ご要望・権利者様からのご連絡は
    <a href="https://github.com/ユーザー名/リポジトリ名/issues">
      GitHub Issues
    </a>
    よりお願いいたします。
  </p>
  -->
</footer>

<dialog id="image-dialog">
  <button id="close-dialog">×</button>
  <img id="dialog-image" src="" alt="" />
</dialog>

<script>
  const dialog = document.getElementById("image-dialog") as HTMLDialogElement;
  const dialogImage = document.getElementById("dialog-image") as HTMLImageElement;
  const closeButton = document.getElementById("close-dialog") as HTMLButtonElement;

  document.querySelectorAll(".zoomable-image").forEach((img) => {
  img.addEventListener("click", () => {
    dialogImage.src = (img as HTMLImageElement).src;
    dialogImage.alt = (img as HTMLImageElement).alt;
    dialog.showModal();
  });
});

  closeButton.addEventListener("click", () => {
    dialog.close();
  });

  dialog.addEventListener("click", (event) => {
    if (event.target === dialog) {
      dialog.close();
    }
  });

</script>

</body>